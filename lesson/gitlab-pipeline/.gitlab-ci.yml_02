default:
  image: fuso19/autonetops_ansible:v3

stages:
  - build
  - validate
  - deploy

hello_build:
  stage: build
  script:
    - source /.venv/bin/activate
    - ansible --version
    - ansible-galaxy collection list cisco.ios

hello_validate:
  stage: validate
  script:
    - source /.venv/bin/activate
    - ansible-inventory -i inventory/inv.yaml --list --vault-password-file ./.vault_pass.txt

hello_deploy:
  stage: deploy
  script:
    - echo "Aqui vou aplicar a mudanca nos devices"